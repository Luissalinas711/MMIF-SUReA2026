# DWT fusion using PyWavelets 

# imports and install
import numpy as np
import os
os.system('pip install PyWavelets -q')
from utils import load_image_pair, display_comparison

# wavelet db2 chosen over Haar because it gives smoother reconstruction
# less blocky edges in the fused result, clearly better for medical images
def dwt_fuse(img_A, img_B, wavelet='db2', level=2):
    # wavelet='db2': Daubechies 2: 4 filter coefficients, 2 vanishing moments
    # smoother reconstruction than Haar. Good balance of quality vs speed
    # level=2: two rounds of LL decomposition
    # level 1 captures fine detail, level 2 captures medium detail
    # going higher adds computation time w/out much improvement

    # decompose both images into wavelet subbands
    # coeffs is a list: [LL_coarsest, (LH1,HL1,HH1), (LH2,HL2,HH2)]
    # index 0 = coarsest approximation, index 1 onward = detail at each level
    coeffs_A = pywt.wavedec2(img_A, wavelet, level=level)
    coeffs_B = pywt.wavedec2(img_B, wavelet, level=level)

    # fuse the LL approximation by averaging
    # both sources contribute equally to the coarse overall structure
    fused_coeffs = [(coeffs_A[0] + coeffs_B[0]) / 2.0]

    # fuse each detail level using the max absolute value rule
    # at each pixel, keep whichever coefficient has the larger magnitude
    # this selects the source with the stronger edge signal at that location
    # LH = horizontal edges 
    # HL = vertical edges  
    # HH = diagonal features  
    for (hA, vA, dA), (hB, vB, dB) in zip(coeffs_A[1:], coeffs_B[1:]):
        fused_coeffs.append((
            np.where(np.abs(hA) >= np.abs(hB), hA, hB),  # horizontal edges
            np.where(np.abs(vA) >= np.abs(vB), vA, vB),  # vertical edges
            np.where(np.abs(dA) >= np.abs(dB), dA, dB),  # diagonal features
        ))
        # note: np.abs is needed here b/c detail coefficients have +/- signs
        # Example: a value of -0.8 is a strong edge, np.maximum would discard it
        # np.abs compares magnitudes and np.where keeps the original sign

    # reconstruct the fused image from all the combined subbands
    reconstructed = pywt.waverec2(fused_coeffs, wavelet)

    # crop back to the original size b/c pywt sometimes adds one pixel
    # because the db2 filter length (4) means (N+3)//2 rounds up slightly
    # 2x that comes out as N+1 rather than N
    # clip to [0,1]
    # small floating point errors can push values outside the valid range after reconstruction
    return np.clip(reconstructed[:img_A.shape[0], :img_A.shape[1]], 0.0, 1.0)


# check images are present before running
ct_files    = sorted(f for f in os.listdir(f'{DATA}/mri_ct')
                     if '_mri_' in f and f.endswith('.png'))
spect_files = sorted(f for f in os.listdir(f'{DATA}/mri_spect')
                     if '_mri_' in f and f.endswith('.png'))
pet_files   = sorted(f for f in os.listdir(f'{DATA}/mri_pet')
                     if '_mri_' in f and f.endswith('.png'))
print(f'Found {len(ct_files)} MRI+CT, {len(spect_files)} MRI+SPECT, {len(pet_files)} MRI+PET pairs')

if len(ct_files) == 0 or len(spect_files) == 0 or len(pet_files) == 0:
    print('Some images missing. Run 00_download_images.py first.')


# fuse all MRI+CT pairs
for mri_file in ct_files:
    ct_file   = mri_file.replace('_mri_', '_ct_')
    pair_name = mri_file.replace('_mri_', '_').replace('.png', '')
    mri, ct   = load_image_pair(f'{DATA}/mri_ct/{mri_file}',
                                 f'{DATA}/mri_ct/{ct_file}')
    fused = dwt_fuse(mri, ct, wavelet='db2', level=2)
    display_comparison(mri, ct, fused,
                       titles=['MRI', 'CT', 'DWT Fused'],
                       save_path=f'{REPO_PATH}/results/dwt/{pair_name}_ct.png')
    print(f'Saved: {pair_name}_ct')


# fuse all MRI+SPECT pairs
for mri_file in spect_files:
    tc_file    = mri_file.replace('_mri_', '_tc_')
    pair_name  = mri_file.replace('_mri_', '_').replace('.png', '')
    mri, spect = load_image_pair(f'{DATA}/mri_spect/{mri_file}',
                                  f'{DATA}/mri_spect/{tc_file}')
    fused = dwt_fuse(mri, spect, wavelet='db2', level=2)
    display_comparison(mri, spect, fused,
                       titles=['MRI', 'SPECT', 'DWT Fused'],
                       save_path=f'{REPO_PATH}/results/dwt/{pair_name}_spect.png')
    print(f'Saved: {pair_name}_spect')


# fuse all MRI+PET pairs
for mri_file in pet_files:
    pet_file  = mri_file.replace('_mri_', '_dg_')
    pair_name = mri_file.replace('_mri_', '_').replace('.png', '')
    mri, pet  = load_image_pair(f'{DATA}/mri_pet/{mri_file}',
                                 f'{DATA}/mri_pet/{pet_file}')
    fused = dwt_fuse(mri, pet, wavelet='db2', level=2)
    display_comparison(mri, pet, fused,
                       titles=['MRI', 'PET', 'DWT Fused'],
                       save_path=f'{REPO_PATH}/results/dwt/{pair_name}_pet.png')
    print(f'Saved: {pair_name}_pet')
