import numpy as np, os
from scipy.ndimage import gaussian_filter
from utils import load_image_pair, display_comparison

ct_files    = sorted(f for f in os.listdir(f'{DATA}/mri_ct')    if '_mri_' in f and f.endswith('.png'))
spect_files = sorted(f for f in os.listdir(f'{DATA}/mri_spect') if '_mri_' in f and f.endswith('.png'))
pet_files   = sorted(f for f in os.listdir(f'{DATA}/mri_pet')   if '_mri_' in f and f.endswith('.png'))
print(f'Found {len(ct_files)} MRI+CT, {len(spect_files)} MRI+SPECT, {len(pet_files)} MRI+PET pairs')

if len(ct_files) == 0 or len(spect_files) == 0 or len(pet_files) == 0:
    print('Some images are missing. Run 01_download_images.py first.')

# Define the Laplacian pyramid fusion function
def laplacian_pyramid_fuse(img_A, img_B, levels=4):
    # levels=4 gives best balance between detail and computation time. Found through trialing

    def gaussian_pyramid(img, n):
        # Build Gaussian pyramid by blurring and downsampling at each level
        pyramid = [img.copy()]
        for _ in range(n - 1):
            pyramid.append(gaussian_filter(pyramid[-1], sigma=1.0)[::2, ::2])
        return pyramid

    def upsample(img, shape):
        # Upsample back to target shape by repeating pixels then blurring
        upsampled = np.repeat(np.repeat(img, 2, axis=0), 2, axis=1)
        return gaussian_filter(upsampled[:shape[0], :shape[1]], sigma=1.0)

    def laplacian_pyramid(gp):
        # Detail at each level = what was lost during downsampling
        detail = [gp[k] - upsample(gp[k+1], gp[k].shape) for k in range(len(gp)-1)]
        detail.append(gp[-1])
        return detail

    def fuse_pyramids(a, b):
        # At each pixel keep whichever detail is stronger
        return [np.where(np.abs(x) >= np.abs(y), x, y) for x, y in zip(a, b)]

    def reconstruct(f):
        # Rebuild full image from fused pyramid levels
        result = f[-1]
        for detail_layer in reversed(f[:-1]):
            result = upsample(result, detail_layer.shape) + detail_layer
        return np.clip(result, 0.0, 1.0)

    pyr_A = laplacian_pyramid(gaussian_pyramid(img_A, levels))
    pyr_B = laplacian_pyramid(gaussian_pyramid(img_B, levels))
    fused = fuse_pyramids(pyr_A, pyr_B)
    return reconstruct(fused)

# Fuse all MRI+CT pairs
for mri_file in ct_files:
    ct_file   = mri_file.replace('_mri_', '_ct_')
    pair_name = mri_file.replace('_mri_', '_').replace('.png', '')
    mri, ct   = load_image_pair(f'{DATA}/mri_ct/{mri_file}',
                                 f'{DATA}/mri_ct/{ct_file}')
    fused = laplacian_pyramid_fuse(mri, ct, levels=4)
    display_comparison(mri, ct, fused,
                       titles=['MRI', 'CT', 'Laplacian Fused'],
                       save_path=f'{REPO_PATH}/results/laplacian/{pair_name}_ct.png')
    print(f'Saved: {pair_name}_ct')

# Fuse all MRI+SPECT pairs
