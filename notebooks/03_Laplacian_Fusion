def laplacian_pyramid_fuse(img_A, img_B, levels=4, sigma=1.0):
    # Build the 1D Gaussian kernel
    # G(x) = exp(-x² / 2σ²)  evaluated at x = -2, -1, 0, 1, 2
    # This is the kernel used for both blurring and upsampling
    kernel_radius = 2
    position = np.arange(-kernel_radius, kernel_radius + 1)   # Range [-2, -1, 0, 1, 2]
    kernel_1d = np.exp(-position**2 / (2 * sigma**2))         # evaluate G(x)
    kernel_1d = kernel_1d / kernel_1d.sum()                     # normalise so weights sum to 1

    # Build the 2D kernel as G(x,y) = G(x) * G(y) to increase efficiency
    # This is allowed because the 2D Gaussian is separable.
    kernel_2d = np.outer(kernel_1d, kernel_1d)    


    # Apply Gaussian blur using 2D convolution
    def gaussian_blur(img):
        H, W = img.shape
        pad = kernel_radius
        # Mirror the image at the borders so edge pixels have 'neighbors'
        # We are artificially extending the image here
        img_extend = np.pad(img, pad, mode='reflect')
        # create new output image with zero values at each pixel 
        output = np.zeros_like(img)
        # Slide the kernel over every pixel (x, y) in the output
        for x in range(H):
            for y in range(W):
                # Extract the neighbourhood patch centred on pixel (x, y)
                patch = img_extend[x : x + 5, y : y + 5]
                # Multiply element-wise with kernel, then sum.
                # this is the convolution part
                output[x, y] = np.sum(patch * kernel_2d)
        return output


    # Downsample by factor 2
    # The factor of 2 means we are only computing output at every other pixel
    def downsample(img):
        return img[::2, ::2]    # output[x,y] = input[2x, 2y]


    # Upsample by factor 2 
    # Insert a zero between every pair of pixels
    # Then blur to fill in the inserted positions 
    def upsample(img, target_shape):
        H, W = img.shape
        # Create doubled-sized output image filled with zeros at every other pixel
        expanded = np.zeros((H * 2, W * 2), dtype=np.float32)
        # Place original pixels at even positions. Odd positions stay zero
        expanded[::2, ::2] = img
        # Blur to fill the zeroed out pixel positions
        # Scale by 4 to compensate for the zeros inserted
        # This is because the kernel sums over 25 values but only ~6-7 are non-zero now
        smoothed = gaussian_blur(expanded) * 4.0
        # Crop to target shape (equal to gp[k].shape in def laplacian_pyramid below)
        #image sizes change by level so must smooth according to the image size at each respective level
        return smoothed[:target_shape[0], :target_shape[1]]


    # Build Gaussian pyramid 
    # G_0 = f(x,y)  (the original image)
    # G_{k+1}(x,y) = Sum[{w(m,n) * G_k(2x+m, 2y+n)]  (blur then downsample)
    def gaussian_pyramid(img, n):
        pyramid = [img.copy()]
        for _ in range(n - 1):
            blurred     = gaussian_blur(pyramid[-1])   # apply G(x,y) kernel
            downsampled = downsample(blurred)           # keep every other pixel
            pyramid.append(downsampled)
        return pyramid


    # Build Laplacian pyramid 
    # Subtract the upsampled coarser (lower) level from the current level
    # The result is the detail lost during the blurring and downsample step
    def laplacian_pyramid(gp):
        detail = []
        for k in range(len(gp) - 1):
            upsampled_next = upsample(gp[k+1], gp[k].shape)  
            Lk = gp[k] - upsampled_next                        
            detail.append(Lk)
        detail.append(gp[-1])   # coarsest level stored as is
        return detail

    # Fuse the two Laplacian pyramids
    # Select whichever coefficient has stronger magnitude at each pixel
    def fuse_pyramids(pyr_A, pyr_B):
        fused = []
        for Lk_A, Lk_B in zip(pyr_A, pyr_B):
            # Compare absolute values pixel by pixel
            mask = np.abs(Lk_A) >= np.abs(Lk_B)   # True where A is stronger
            Fk = np.where(mask, Lk_A, Lk_B)        # keep the stronger one
            fused.append(Fk)
        return fused


    # Reconstruct from fused pyramid
    # Add the detail back level by level,
    def reconstruct(fused_pyr):
        result = fused_pyr[-1]   # start from the coarsest fused level
        for Fk in reversed(fused_pyr[:-1]):
            result = upsample(result, Fk.shape) + Fk 
        return np.clip(result, 0.0, 1.0)               


    # Run all steps 
    pyr_A  = laplacian_pyramid(gaussian_pyramid(img_A, levels))
    pyr_B  = laplacian_pyramid(gaussian_pyramid(img_B, levels))
    fused  = fuse_pyramids(pyr_A, pyr_B)
    return reconstruct(fused)

